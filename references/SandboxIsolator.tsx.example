import React from 'react';

// ==========================================
// 💡 SandboxIsolator — isolate interactive-demo events
// ==========================================
//
// Wrap any embedded interactive demo (input, terminal, clickable mini-game) with this. Otherwise a
// space / arrow key, a scroll, or a click inside the demo bubbles up to the global deck listeners
// and flips the slide or jumps a beat — the user is mid-typing and gets navigated away. Bad.
//
// It does exactly one thing: stop key / wheel / click events from bubbling out of the demo.

export const SandboxIsolator: React.FC<{ children: React.ReactNode }> = ({ children }) => (
  <div
    onKeyDown={(e) => e.stopPropagation()} // space / arrows / enter no longer trigger navigation
    onWheel={(e) => e.stopPropagation()}   // scrolling no longer mis-fires navigation
    onClick={(e) => e.stopPropagation()}   // clicks no longer trigger click-to-next
    className="w-full h-full"
  >
    {children}
  </div>
);
