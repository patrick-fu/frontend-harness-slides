import React from 'react';

// ==========================================
// 💡 SlideRegistry — painless routing & dynamic registration
// ==========================================
//
// The pain: traditional decks hardcode order in filenames (Scene1.tsx, Scene2.tsx) or in App.tsx.
// Inserting a slide mid-deck forces renaming every later file, rewriting imports, and renumbering
// every Playwright snapshot path — "re-indexing hell", with broken snapshots.
//
// The fix:
// 1. Name scene components semantically, with no ordinal in the name (CoverSlide, HarnessSlide).
// 2. One central SLIDE_REGISTRY array declares order.
// 3. Routing, page numbers, and tests all derive from array position — inserting a slide is just
//    editing the array; physical filenames never change.

export interface SlideEntry {
  id: string;         // stable, persistent id — used in routes and as the Playwright snapshot filename; don't change it casually
  title: string;      // slide title, for the framework / page title / outline
  component: React.ComponentType<{ currentBeat: number; isTestMode?: boolean }>;
  totalBeats: number; // number of beats inside this slide (excluding beat 0)
}

// Placeholder scene components (in a real deck, import the actual scene files instead).
const DummyCoverSlide: React.FC<{ currentBeat: number }> = () => <div>Cover</div>;
const DummyHarnessSlide: React.FC<{ currentBeat: number }> = () => <div>Harness premise</div>;
const DummyLoopSlide: React.FC<{ currentBeat: number }> = () => <div>Loop definition</div>;

export const SLIDE_REGISTRY: SlideEntry[] = [
  {
    id: 'cover',
    title: 'From Spec to Loop',
    component: DummyCoverSlide,
    totalBeats: 1,
  },
  {
    id: 'harness-premise',
    title: 'The harness is the premise, not the star',
    component: DummyHarnessSlide,
    totalBeats: 3, // e.g. beat 1 gate appears, beat 2 conveyor wraps, beat 3 hard case lands
  },
  {
    id: 'loop-definition',
    title: 'What a controllable loop is',
    component: DummyLoopSlide,
    totalBeats: 4, // e.g. beat 1 console, beat 2 indicator, beat 3 state flows, beat 4 write-back
  },
];

/**
 * Derive prev/next navigation from the registry.
 */
export const getSlideNavigation = (currentId: string) => {
  const currentIndex = SLIDE_REGISTRY.findIndex(s => s.id === currentId);
  if (currentIndex === -1) return { prev: null, next: null, current: SLIDE_REGISTRY[0] };

  const prev = currentIndex > 0 ? SLIDE_REGISTRY[currentIndex - 1] : null;
  const next = currentIndex < SLIDE_REGISTRY.length - 1 ? SLIDE_REGISTRY[currentIndex + 1] : null;

  return {
    prev,
    next,
    current: SLIDE_REGISTRY[currentIndex],
    index: currentIndex,
    total: SLIDE_REGISTRY.length,
  };
};

// ==========================================
// 💡 Expose a slim list for tooling (tests / PDF export)
// ==========================================
//
// The visual / auditor specs and export-pdf.mjs all need to know "which scenes exist and how many
// beats each has". Let them read this runtime list instead of each hardcoding its own copy —
// SLIDE_REGISTRY stays the single source of truth. Call this once at the SlideDeck entry point.

declare global {
  interface Window {
    __SLIDE_REGISTRY__?: { id: string; totalBeats: number }[];
  }
}

export const exposeRegistryForTooling = () => {
  if (typeof window !== 'undefined') {
    window.__SLIDE_REGISTRY__ = SLIDE_REGISTRY.map(s => ({ id: s.id, totalBeats: s.totalBeats }));
  }
};
