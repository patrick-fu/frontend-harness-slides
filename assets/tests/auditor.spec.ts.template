import { test, expect } from '@playwright/test';

// ==========================================
// 💡 Auditor — structural & layout safety audit (not pixels)
// ==========================================
// Walks every scene/beat in the registry and runs two checks:
// 1) Font floor: visible copy must not render below 16px (tiny text is an anti-slop tell and hurts legibility).
// 2) Overflow: no visible element may escape [data-slide-stage]; deliberate bleed must be flagged with data-allow-overflow.
// The slide list is read at runtime from window.__SLIDE_REGISTRY__ (single source). Checks run inside page.evaluate for speed.

test('layout & legibility audit — every registered scene / beat', async ({ page }) => {
  await page.setViewportSize({ width: 1920, height: 1080 });

  await page.goto('/?test=true', { waitUntil: 'networkidle' });
  const registry = await page.evaluate(() => window.__SLIDE_REGISTRY__ ?? []);
  expect(registry.length, 'window.__SLIDE_REGISTRY__ is empty: call exposeRegistryForTooling() at startup').toBeGreaterThan(0);

  for (const { id, totalBeats } of registry) {
    for (let beat = 0; beat <= totalBeats; beat++) {
      await page.goto(`/?scene=${id}&beat=${beat}&test=true`, { waitUntil: 'networkidle' });
      await page.evaluate(() => document.fonts.ready);
      const where = `${id} beat ${beat}`;

      // —— Check 1: 16px font floor ——
      const tooSmall = await page.evaluate(() => {
        const offenders: string[] = [];
        for (const el of document.querySelectorAll('span, p, h1, h2, h3, h4, li, div')) {
          const text = (el.textContent ?? '').trim();
          if (text.length <= 2 || /^[0-9\-\s:+]+$/.test(text)) continue; // skip pure numbers / symbols / very short
          const r = el.getBoundingClientRect();
          if (r.width === 0 || r.height === 0) continue;                  // skip invisible
          const size = parseFloat(getComputedStyle(el).fontSize);
          if (size < 16) offenders.push(`${size}px "${text.slice(0, 30)}"`);
        }
        return offenders;
      });
      expect.soft(tooSmall, `${where}: text below 16px`).toEqual([]);

      // —— Check 2: escapes [data-slide-stage] ——
      const escaped = await page.evaluate(() => {
        const stage = document.querySelector('[data-slide-stage]');
        if (!stage) return ['[data-slide-stage] not found (does SlideStage carry the attribute?)'];
        const s = stage.getBoundingClientRect();
        const offenders: string[] = [];
        for (const el of document.querySelectorAll('[data-slide-stage] *')) {
          if ((el as HTMLElement).closest('[data-allow-overflow]')) continue; // deliberate bleed, explicitly allowed
          const r = el.getBoundingClientRect();
          if (r.width === 0 || r.height === 0) continue;
          const out =
            r.left < s.left - 0.5 || r.top < s.top - 0.5 ||
            r.right > s.right + 0.5 || r.bottom > s.bottom + 0.5;
          if (out) offenders.push(`<${el.tagName.toLowerCase()}> "${(el.textContent ?? '').trim().slice(0, 30)}"`);
        }
        return offenders;
      });
      expect.soft(escaped, `${where}: element escapes the stage`).toEqual([]);
    }
  }
});
