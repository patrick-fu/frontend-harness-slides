import { test, expect } from '@playwright/test';
import type { Page } from '@playwright/test';

// ==========================================
// 💡 Visual — deterministic pixel regression (frozen frame)
// ==========================================
// Pixel-compares every beat of every scene in the registry.
// The slide list is read at runtime from window.__SLIDE_REGISTRY__ (single source of truth) — not
// duplicated here. Runs on chromium only (one baseline, less CI bandwidth); the cross-platform
// snapshot suffix is matched automatically (macOS -> *-chromium-darwin.png, Ubuntu -> *-chromium-linux.png).

// freeze: pause every continuous / infinite animation, zero transitions, lock the first frame.
// This is the single source of the freeze mechanism (export-pdf.mjs reuses the same rule).
const FREEZE_CSS = `
  *, *::before, *::after {
    animation-play-state: paused !important;
    transition-delay: 0s !important;
    transition-duration: 0s !important;
  }
`;

test('pixel regression — every registered scene / beat', async ({ page }, testInfo) => {
  test.skip(testInfo.project.name !== 'chromium', 'Visual snapshots run on Chromium desktop only.');
  await page.setViewportSize({ width: 1920, height: 1080 });

  // read the single source of truth
  await page.goto('/?test=true', { waitUntil: 'networkidle' });
  const registry = await page.evaluate(() => window.__SLIDE_REGISTRY__ ?? []);
  expect(registry.length, 'window.__SLIDE_REGISTRY__ is empty: call exposeRegistryForTooling() at startup').toBeGreaterThan(0);

  for (const { id, totalBeats } of registry) {
    for (let beat = 0; beat <= totalBeats; beat++) {
      await page.goto(`/?scene=${id}&beat=${beat}&test=true`, { waitUntil: 'networkidle' });
      await page.evaluate(() => document.fonts.ready); // wait for fonts to load
      await page.addStyleTag({ content: FREEZE_CSS });  // freeze continuous motion
      await waitForAnimationsToSettle(page);            // wait for Framer Motion physics to settle

      // expect.soft: audit the whole deck and aggregate failures; one diff won't abort the rest
      await expect.soft(page).toHaveScreenshot(`${id}-beat-${beat}.png`, {
        maxDiffPixelRatio: 0.01, // allow 1% sub-pixel antialiasing diff to absorb cross-platform rendering
        fullPage: true,
        // mask regions that can't be frozen (live canvas, third-party iframes)
        mask: [page.locator('[data-live-region]'), page.locator('iframe')],
      });
    }
  }
});

/**
 * Settle poller: when two consecutive frames show no change in element position/opacity, the page
 * is physically at rest — then it's safe to screenshot.
 */
async function waitForAnimationsToSettle(page: Page) {
  let previous = '';
  for (let attempt = 0; attempt < 20; attempt++) { // wait at most 1s (50ms * 20)
    const current = await page.evaluate(() =>
      Array.from(document.querySelectorAll('div, span, p, h1, h2, img, button'))
        .map((el) => {
          const r = el.getBoundingClientRect();
          return `${r.top},${r.left},${r.width},${r.height},${getComputedStyle(el).opacity}`;
        })
        .join('|')
    );
    if (current === previous) break;
    previous = current;
    await page.waitForTimeout(50);
  }
}
