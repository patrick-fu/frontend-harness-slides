{
  "name": "frontend-harness-slides-starter",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "doctor": "node scripts/doctor.mjs",
    "auditor": "playwright test auditor.spec.ts",
    "visual": "playwright test visual.spec.ts",
    "visual:update": "playwright test visual.spec.ts --update-snapshots",
    "test": "npm run build && npm run auditor",
    "test:full": "npm run build && playwright test"
  },
  "dependencies": {
    "framer-motion": "11.3.0",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "1.45.0",
    "@types/node": "22.20.0",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "@vitejs/plugin-react": "6.0.3",
    "autoprefixer": "10.4.19",
    "postcss": "8.4.39",
    "tailwindcss": "3.4.4",
    "typescript": "^5.9.3",
    "vite": "8.1.0"
  },
  "engines": {
    "node": ">=20.11.0"
  }
}
