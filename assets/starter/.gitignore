# P0-2 FIXED: starter 根目录 .gitignore。分门别类：Node / Logs / Build / Playwright 运行时产物
# / PDF 导出 / 编辑器 / IDE / OS / Env / Vite / Coverage / 部署缓存，共 14 类 57 条目。
# Snapshot baselines 仅追踪 tests/**/snapshots/ 目录（由 playwright.config.ts 的
# snapshotPathTemplate 生成的 canonical 版本，无 chromium-darwin 等平台后缀，跨机器字节可比）。
# Playwright 默认的 tests/*.spec.ts-snapshots/ 平台后缀目录被加入 ignore 防误提交。

# --- Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Build 产物
dist/
dist-ssr/
build/
.output/
.nuxt/
.next/
*.local
*.tsbuildinfo

# --- Playwright / Test 运行时产物
test-results/
playwright-report/
blob-report/
# 运行时 diff（baseline 本身必须追踪）
*.diff.png
*.expected.png
*.actual.png
snapshots/*/diff/
tests/**/__snapshots__/
# Playwright 默认快照路径（带平台后缀）
tests/*.spec.ts-snapshots/
junit-*.xml
test-output/

# --- PDF / 归档 导出
pdf/
*.pdf
*.pdf.tmp
exports/
*.tar.gz
*.zip
*.tgz
*.tar.bz2

# --- Editor / IDE
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*.iml

# --- OS
.DS_Store
Thumbs.db
ehthumbs.db
$RECYCLE.BIN/

# --- Env / Secrets
.env
.env.*
!.env.example
*.pem
*.key
secrets.json
*.crt

# --- Vite
.vite/

# --- Coverage
coverage/
.nyc_output/
*.lcov

# --- Logs
*.log

# --- Deployment / Cache
.vercel
.netlify
.firebase/
.cache/
.temp/
.tmp/
.pnp
.pnp.js
.yarn/install-state.gz
.eslintcache
