# Optional, portable CI for the harness. Drop the `.example` suffix to enable it on GitHub.
name: harness
on:
  push:
    branches: [main]
  pull_request:
jobs:
  harness:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      # H-9: align Node runtime with package.json engines.node (>= 20.11.0).
      # Using the 20.x line keeps LTS semantics; if 22.x is preferred locally the
      # engines spec is satisfied by either.
      - uses: actions/setup-node@v4
        with:
          node-version: '20.11.0'

      # H-9: cache ~/.npm so npm ci is near-instant on 2nd+ runs of the same lockfile.
      - name: Cache npm
        uses: actions/cache@v4
        with:
          path: ~/.npm
          key: ${{ runner.os }}-npm-${{ hashFiles('**/package-lock.json') }}
          restore-keys: |
            ${{ runner.os }}-npm-

      - run: npm ci

      # H-9: cache Playwright's Chromium binary (~300MB) so we don't re-download on every run.
      # The key is pinned to the exact @playwright/test version declared in package.json —
      # bumping the version there auto-invalidates this cache.
      - name: Cache Playwright browsers
        uses: actions/cache@v4
        id: playwright-cache
        with:
          path: ~/.cache/ms-playwright
          key: ${{ runner.os }}-playwright-${{ hashFiles('package-lock.json') }}

      - name: Install Playwright browsers
        if: steps.playwright-cache.outputs.cache-hit != 'true'
        run: npx playwright install --with-deps chromium

      # Optional: compile a heavy CJK web font on the fly instead of committing the binary.
      # NOTE: ttf2woff2 only converts the container; for real CJK size reduction use
      # glyphhanger/pyftsubset subsetting — see references/deploy.md.
      # - run: npx ttf2woff2 < public/fonts/LXGWWenKaiLite-Regular.ttf > public/fonts/LXGWWenKaiLite-Regular.woff2

      - run: npm run build

      - name: Run Playwright harness
        run: npx playwright test

      # H-9: always upload the report + diff PNGs even on failure, so flaky/red builds can
      # be diagnosed from the GitHub UI without re-running locally. Retention of 14 days
      # balances debuggability against long-term storage cost.
      - name: Upload test artifacts
        uses: actions/upload-artifact@v4
        if: always()
        with:
          name: playwright-report
          path: |
            playwright-report/
            test-results/
            tests/visual.spec.ts-snapshots/
          retention-days: 14
